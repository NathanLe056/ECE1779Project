{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2023",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@prisma/client": ["./generated/prisma/index.d.ts"]
    }
  },
  "include": ["src/**/*", "generated/prisma/index.d.ts"],
  "exclude": ["node_modules"]
}